# @BotFather 에서 발급받은 텔레그램 봇 토큰
TELEGRAM_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyz

# 사용할 Ollama 모델 (선택)
# 후보: qwen3:4b (범용, thinking 자동 off) / exaone3.5:2.4b (한국어 강점) / gemma3:4b
OLLAMA_MODEL=qwen3:4b

# 봇을 쓸 수 있는 chat_id 목록 (콤마 구분, 선택)
# 비워두면 누구나 사용 가능. 값이 있으면 해당 ID만 허용.
# 예) ALLOWED_CHAT_IDS=123456789,987654321
ALLOWED_CHAT_IDS=

# 웹훅 비밀 토큰 (선택, 권장)
# setWebhook 호출 시 secret_token 파라미터와 "똑같은 값"을 여기에 넣는다.
# 텔레그램이 매 요청에 X-Telegram-Bot-Api-Secret-Token 헤더로 보내고,
# 봇이 이 값과 비교해 일치하지 않는 직접 호출을 403으로 거절한다.
# 값 생성 예) openssl rand -hex 32
# 등록 예) curl "https://api.telegram.org/bot<토큰>/setWebhook" \
#            -d "url=https://도메인/telegram" -d "secret_token=여기값"
WEBHOOK_SECRET=

# Tavily 웹 검색 API 키 (선택). https://tavily.com 무료 발급(월 1000회)
# 있으면 본문·요약까지 받아 날씨·스코어 등 구체 사실에 강함.
# 비워두면 DuckDuckGo(스니펫만)로 자동 폴백.
TAVILY_API_KEY=

# 에어컨 IR 제어 서버(ir_server) 주소 (선택)
# 봇이 같은 파이 위(host networking)면 기본값으로 충분.
IR_SERVER_URL=http://127.0.0.1:8000

# ir_server 에 인증을 켰을 때만 입력(서버의 IR_HTTP_TOKEN 과 동일 값).
# 비워두면 무인증으로 호출.
IR_HTTP_TOKEN=
